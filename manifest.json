{
  "manifest_version": 3,
  "name": "Gemini Folders",
  "version": "1.0.1",
  "description": "Adds a folder organizer to the Gemini sidebar.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://gemini.google.com/*"],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "backup/popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "js/utils.js",
        "js/storage.js",
        "js/ui-components.js",
        "js/navigation.js",
        "js/main.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ]
}
{
  "manifest_version": 3,
  "name": "Gemini Folders",
  "version": "1.0.0",
  "description": "Adds a folder organizer to the Gemini sidebar.",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_popup": "backup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "js/utils.js",
        "js/storage.js",
        "js/ui-components.js",
        "js/navigation.js",
        "js/main.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ]
}
